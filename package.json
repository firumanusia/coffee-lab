{
  "name": "menoowel-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @menoowel/web",
    "dev:web": "npm run dev -w @menoowel/web",
    "build:web": "npm run build -w @menoowel/web",
    "dev:api": "npm run start:dev -w @menoowel/api",
    "build:api": "npm run build -w @menoowel/api",
    "dev:admin": "npm run dev -w @menoowel/admin",
    "build:admin": "npm run build -w @menoowel/admin"
  }
}
