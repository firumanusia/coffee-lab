# Copy to .env (git-ignored). In prod these are set in Coolify.
DATABASE_URL="postgresql://menoowel:CHANGE_ME@localhost:5432/menoowel?schema=public"
PORT=3000
NODE_ENV=development

# CORS allowlist (comma-separated)
CORS_ORIGINS="http://localhost:5173,http://localhost:5174,https://menoowel.com,https://admin.menoowel.com"

# Auth (Phase 3)
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_ACCESS_TTL="900s"
JWT_REFRESH_TTL="30d"

# Google OAuth (Phase 3)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3000/v1/auth/google/callback"
WEB_URL="http://localhost:5173"

# SMTP (email verification)
SMTP_HOST="mail.menoowel.com"
SMTP_PORT="587"
SMTP_USER="no-reply@menoowel.com"
SMTP_PASS=""
MAIL_FROM="MENOOWEL <no-reply@menoowel.com>"
